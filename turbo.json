{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "type:check": {
      "inputs": [
        "tsconfig.json",
        "src/**"
      ],
      "outputs": [
        "*.tsbuildinfo"
      ],
      "env": [
        "VITE_NOTION_TOKEN",
        "VITE_NOTION_CULINARIES_DATASOURCE_ID",
        "VITE_NOTION_PRODUCTS_DATASOURCE_ID"
      ]
    },
    "biome:check": {
      "outputs": [],
      "inputs": [
        "biome.json",
        "src/**"
      ]
    },
    "biome:ci": {
      "outputs": [],
      "inputs": [
        "biome.json",
        "src/**"
      ]
    },
    "build": {
      "dependsOn": ["type:check"],
      "outputs": [
        "dist/**",
        "public/**"
      ],
      "env": [
        "VITE_NOTION_TOKEN",
        "VITE_NOTION_CULINARIES_DATASOURCE_ID",
        "VITE_NOTION_PRODUCTS_DATASOURCE_ID"
      ]
    },
    "test": {
      "outputs": [
        "node_modules/.vite/vitest/**/results.json"
      ],
      "inputs": [
        "vitest.config.ts",
        "src/**"
      ]
    }
  }
}