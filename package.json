{
  "name": "savorsanctum",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "serve": "vite preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest --coverage run",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "check:turbo": "pnpm turbo biome:check type:check test",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/fredoka": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@notionhq/client": "^5.6.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-pacer": "^0.19.0",
    "@tanstack/react-router": "1.144.0",
    "@tanstack/react-router-devtools": "1.144.0",
    "@tanstack/react-start": "1.145.5",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "1.145.4",
    "@tanstack/zod-adapter": "^1.144.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.28",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.70.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@commitlint/types": "^20.2.0",
    "@julr/vite-plugin-validate-env": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "commit-and-tag-version": "^12.6.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "nitro": "npm:nitro-nightly@3.0.1-20260105-143911-656a71ed",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@7.2.11",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16",
    "web-vitals": "^5.1.0"
  },
  "version": "1.1.0"
}
