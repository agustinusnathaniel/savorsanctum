{
  "name": "savorsanctum",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "generate-pwa-assets": "pwa-assets-generator",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vp test run",
    "test:ui": "vp test --ui --coverage",
    "test:coverage": "vp test --coverage run",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "check:turbo": "pnpm turbo biome:check type:check test",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "prepare": "vp config",
    "validate:csp": "tsx scripts/validate-csp.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/fredoka": "^5.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@notionhq/client": "^5.22.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.18",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "1.168.13",
    "@tanstack/zod-adapter": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@cloudflare/vite-plugin": "^1.40.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@julr/vite-plugin-validate-env": "^2.2.2",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "commit-and-tag-version": "^12.7.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-checker": "^0.14.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "web-vitals": "^5.3.0",
    "wrangler": "^4.99.0"
  },
  "version": "1.2.2"
}
