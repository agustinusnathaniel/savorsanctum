{
  "name": "savorsanctum",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "serve": "vp preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vp test run",
    "test:ui": "vp test --ui --coverage",
    "test:coverage": "vp test --coverage run",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "check:turbo": "pnpm turbo biome:check type:check test",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/fredoka": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@notionhq/client": "^5.12.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-pacer": "^0.20.0",
    "@tanstack/react-router": "1.166.7",
    "@tanstack/react-router-devtools": "1.166.7",
    "@tanstack/react-start": "1.166.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "1.166.7",
    "@tanstack/zod-adapter": "^1.166.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/types": "^20.4.4",
    "@julr/vite-plugin-validate-env": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.5.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.0",
    "commit-and-tag-version": "^12.6.1",
    "cross-env": "^10.1.0",
    "jsdom": "^28.1.0",
    "nitro": "3.0.260311-beta",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "web-vitals": "^5.1.0",
    "vite-plus": "latest"
  },
  "version": "1.1.0"
}
