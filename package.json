{
  "name": "savorsanctum",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "type:check": "tsc",
    "test": "vp test run",
    "test:ui": "vp test --ui --coverage",
    "test:coverage": "vp test --coverage run",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "check:turbo": "turbo biome:check type:check test",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "prepare": "vp config",
    "validate:csp": "tsx scripts/validate-csp.ts",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/fredoka": "^5.2.10",
    "@notionhq/client": "^5.22.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.18",
    "@tanstack/router-plugin": "1.168.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@cloudflare/vite-plugin": "^1.42.3",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@julr/vite-plugin-validate-env": "^2.2.2",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-vite": "^0.7.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "commit-and-tag-version": "^12.7.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.1",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "catalog:",
    "vitest": "4.1.9",
    "wrangler": "^4.105.0"
  },
  "version": "1.2.3"
}
